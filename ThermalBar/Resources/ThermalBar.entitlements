<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow app to run as a menu bar agent -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- IOKit exception: allow opening the AppleSMC user client for temperature reading -->
    <key>com.apple.security.temporary-exception.iokit-user-client-class</key>
    <array>
        <string>AppleSMCClient</string>
    </array>
</dict>
</plist>
